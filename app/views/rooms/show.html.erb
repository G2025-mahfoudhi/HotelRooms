<%# <h1>Rooms#show</h1> %>
<%# <p>Find me in app/views/rooms/show.html.erb</p> %>
<div class="container mt-4">
  <%= link_to "← Retour à l'hôtel", hotel_path(@hotel), class: "btn btn-outline-secondary mb-3" %>
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Accueil", root_path %></li>
      <li class="breadcrumb-item"><%= link_to @hotel.name, hotel_path(@hotel) %></li>
      <li class="breadcrumb-item active"><%= @room.room_type %></li>
    </ol>
  </nav>

  <div class="row mt-3">
    <div class="col-md-7">
      <% if @room.photos.attached? %>
        <div id="roomCarousel" class="carousel slide" data-bs-ride="carousel">
          <div class="carousel-inner">
            <% @room.photos.each_with_index do |photo, index| %>
              <div class="carousel-item <%= 'active' if index == 0 %>">
                <%= image_tag photo, class: "room-detail-img d-block w-100 rounded" %>
              </div>
            <% end %>
          </div>
          <button class="carousel-control-prev" type="button" data-bs-target="#roomCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#roomCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
          </button>
        </div>
      <% else %>
        <img src="https://images.unsplash.com/photo-1631049307264-da0ec9d70304?w=800" class="room-detail-img rounded" alt="<%= @room.room_type %>">
      <% end %>
    </div>

    <div class="col-md-5">
      <div class="card p-4">
        <h2><%= @room.room_type %></h2>
        <p class="text-muted"><i class="bi bi-building me-1"></i><%= @hotel.name %> — <%= @hotel.city %></p>
        <hr>
        <div class="d-flex align-items-center mb-3">
          <i class="bi bi-tag me-2 text-primary"></i>
          <span class="fs-4 fw-bold text-primary"><%= @room.price %>€/nuit</span>
        </div>
        <div class="mb-3">
          <p><i class="bi bi-check-circle-fill text-success me-2"></i>Petit déjeuner inclus</p>
          <p><i class="bi bi-check-circle-fill text-success me-2"></i>Wifi gratuit</p>
          <p><i class="bi bi-check-circle-fill text-success me-2"></i>Annulation gratuite</p>
        </div>
        <hr>
        <% if user_signed_in? %>
          <%= link_to "Réserver cette chambre", new_hotel_room_booking_path(@hotel, @room), class: "btn btn-primary w-100 btn-lg" %>
        <% else %>
          <%= link_to "Connexion pour réserver", new_user_session_path, class: "btn btn-outline-primary w-100 btn-lg" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
