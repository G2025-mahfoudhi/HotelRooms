<%# <h1>Users#show</h1> %>
<%# <p>Find me in app/views/users/show.html.erb</p> %>
<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card p-4 text-center">
        <% if current_user.avatar.attached? %>
          <div class="position-relative d-inline-block mx-auto mb-3">
            <%= image_tag current_user.avatar, class: "rounded-circle", style: "width: 120px; height: 120px; object-fit: cover;" %>
            <div class="dropdown position-absolute bottom-0 end-0">
              <button class="btn bg-warning rounded-circle p-1" data-bs-toggle="dropdown">
                <i class="bi bi-camera-fill"></i>
              </button>
               <ul class="dropdown-menu">
                <li>
                  <a class="dropdown-item" data-bs-toggle="modal" data-bs-target="#photoModal">Voir ma photo</a>
                </li>
                <li>
                  <%= button_to "Supprimer", user_path(current_user), method: :patch,
                      params: { user: { remove_avatar: "1" } },
                      class: "dropdown-item text-danger border-0 bg-transparent",
                      form: { data: { turbo_confirm: "Supprimer votre photo ?" } } %>
                </li>
              </ul>
              </ul>
            </div>
          </div>
        <% else %>
          <div class="position-relative d-inline-block mx-auto mb-3">
            <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center mx-auto" style="width: 120px; height: 120px;">
              <i class="bi bi-person-fill text-white" style="font-size: 3rem;"></i>
            </div>
            <%= link_to edit_user_path(current_user), class: "position-absolute bottom-0 end-0 bg-warning rounded-circle p-1" do %>
              <i class="bi bi-camera-fill"></i>
            <% end %>
          </div>
        <% end %>

        <h3><%= current_user.first_name %> <%= current_user.last_name %></h3>
        <p class="text-muted"><%= current_user.email %></p>

        <hr>

        <%= link_to "Modifier mon profil", edit_user_path(current_user), class: "btn btn-primary w-100 mb-2" %>
        <%= link_to "Mes réservations", bookings_path, class: "btn btn-outline-secondary w-100" %>
      </div>
    </div>
  </div>
</div>

<% if current_user.avatar.attached? %>
  <div class="modal fade" id="photoModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Ma photo</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body text-center">
          <%= image_tag current_user.avatar, class: "img-fluid rounded" %>
        </div>
      </div>
    </div>
  </div>
<% end %>
