<%# <h1>Users#edit</h1> %>
<%# <p>Find me in app/views/users/edit.html.erb</p> %>
<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card p-4">
        <h2 class="mb-4 text-center">Modifier mon profil</h2>

        <%= simple_form_for @user, html: { multipart: true } do |f| %>
          <div class="text-center mb-3">
            <% if @user.avatar.attached? %>
              <%= image_tag @user.avatar, class: "rounded-circle mb-2", style: "width: 100px; height: 100px; object-fit: cover;" %>
            <% else %>
              <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center mx-auto mb-2" style="width: 100px; height: 100px;">
                <i class="bi bi-person-fill text-white" style="font-size: 2.5rem;"></i>
              </div>
            <% end %>
            <%= f.input :avatar, as: :file, label: "Photo de profil" %>
          </div>

          <%= f.input :first_name, label: "Prénom" %>
          <%= f.input :last_name, label: "Nom" %>
          <%= f.input :email, label: "Email" %>

          <hr>
          <p class="text-muted small">Laissez vide si vous ne souhaitez pas changer le mot de passe</p>
          <%= f.input :password, label: "Nouveau mot de passe", required: false %>
          <%= f.input :password_confirmation, label: "Confirmer le mot de passe", required: false %>
          <%= f.input :current_password, label: "Mot de passe actuel (obligatoire)", required: true %>

          <%= f.submit "Enregistrer", class: "btn btn-primary w-100 mt-3" %>
        <% end %>

        <%= link_to "← Retour", user_path(@user), class: "btn btn-outline-secondary w-100 mt-2" %>
      </div>
    </div>
  </div>
</div>
