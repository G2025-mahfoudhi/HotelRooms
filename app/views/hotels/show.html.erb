<%# <h1>Hotels#show</h1> %>
<%# <p>Find me in app/views/hotels/show.html.erb</p> %>

<% if @hotel.photos.attached? %>
  <div id="hotelCarousel" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">
      <% @hotel.photos.each_with_index do |photo, index| %>
        <div class="carousel-item <%= 'active' if index == 0 %>">
          <%= image_tag photo, class: "hotel-hero-img d-block w-100" %>
        </div>
      <% end %>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#hotelCarousel" data-bs-slide="prev">
      <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#hotelCarousel" data-bs-slide="next">
      <span class="carousel-control-next-icon"></span>
    </button>
  </div>
<% else %>
  <img src="<%= @hotel.photo_url %>" class="hotel-hero-img" alt="<%= @hotel.name %>">
<% end %>

<div class="container mt-4">
  <%= link_to "← Retour à l'accueil", root_path, class: "btn btn-outline-secondary mb-3" %>
  <h1><%= @hotel.name %></h1>
  <p><i class="bi bi-geo-alt me-1 text-warning"></i><strong class="text-warning"><%= @hotel.city %></strong></p>
  <p><%= @hotel.description %></p>

  <h2 class="mt-4 mb-3">Chambres disponibles</h2>
  <div class="row">
    <% @rooms.each do |room| %>
      <div class="col-md-4 mb-4">
        <div class="card h-100">
          <% if room.photos.attached? %>
            <%= image_tag room.photos.first, class: "card-img-top" %>
          <% else %>
            <img src="https://images.unsplash.com/photo-1631049307264-da0ec9d70304?w=800" class="card-img-top" alt="<%= room.room_type %>">
          <% end %>
          <div class="card-body d-flex flex-column">
            <h5 class="card-title"><%= room.room_type %></h5>
            <p class="card-text fw-bold"><%= room.price %>€/nuit</p>
            <div class="mt-auto">
              <%= link_to "Voir la chambre", hotel_room_path(@hotel, room), class: "btn btn-primary w-100" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <h2 class="mt-5 mb-3">Avis clients</h2>
  <% if @hotel.reviews.empty? %>
    <p class="text-muted">Aucun avis pour le moment.</p>
  <% else %>
    <% @hotel.reviews.each do |review| %>
      <div class="card mb-3">
        <div class="card-body">
          <div class="d-flex justify-content-between">
            <strong><%= review.user.first_name %> <%= review.user.last_name %></strong>
            <span class="text-warning">
              <% review.rating.times do %><i class="bi bi-star-fill"></i><% end %>
            </span>
          </div>
          <p class="mt-2 mb-0"><%= review.comment %></p>
        </div>
      </div>
    <% end %>
  <% end %>

  <% if user_signed_in? %>
    <h3 class="mt-4">Laisser un avis</h3>
    <%= simple_form_for [@hotel, @review] do |f| %>
      <%= f.input :rating, label: "Note", as: :select, collection: (1..5), include_blank: false %>
      <%= f.input :comment, label: "Commentaire", as: :text %>
      <%= f.submit "Envoyer", class: "btn btn-primary" %>
    <% end %>
  <% end %>
</div>
