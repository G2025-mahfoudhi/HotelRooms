<%# <h1>Bookings#new</h1> %>
<%# <p>Find me in app/views/bookings/new.html.erb</p> %>

<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card p-4">
        <h2 class="mb-3">Réserver une chambre</h2>
        <hr>
        <p><i class="bi bi-building me-2 text-warning"></i><strong><%= @hotel.name %></strong> — <%= @hotel.city %></p>
        <p><i class="bi bi-door-open me-2 text-primary"></i><%= @room.room_type %> — <strong><%= @room.price %>€/nuit</strong></p>
        <hr>
        <%= form_with model: [@hotel, @room, @booking] do |f| %>
          <div class="mb-3">
            <%= f.label :start_date, "Date d'arrivée", class: "form-label" %>
            <%= f.date_field :start_date, class: "form-control" %>
          </div>
          <div class="mb-3">
            <%= f.label :end_date, "Date de départ", class: "form-label" %>
            <%= f.date_field :end_date, class: "form-control" %>
          </div>
          <%= f.submit "Confirmer la réservation", class: "btn btn-primary w-100 mt-2" %>
        <% end %>
        <%= link_to "← Retour", hotel_room_path(@hotel, @room), class: "btn btn-outline-secondary w-100 mt-2" %>
      </div>
    </div>
  </div>
</div>
