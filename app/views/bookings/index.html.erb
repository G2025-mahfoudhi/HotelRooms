<%# <h1>Bookings#index</h1> %>
<%# <p>Find me in app/views/bookings/index.html.erb</p> %>
<div class="container mt-4">
  <h1>Mes réservations</h1>

  <% if @bookings.empty? %>
    <p>Vous n'avez pas encore de réservations.</p>
  <% else %>
    <div class="row">
      <% @bookings.each do |booking| %>
        <div class="col-md-6 mb-4">
          <div class="card">
            <div class="card-body">
              <h5 class="card-title"><%= booking.room.hotel.name %></h5>
              <p><strong>Chambre :</strong> <%= booking.room.room_type %></p>
              <p><strong>Arrivée :</strong> <%= booking.start_date %></p>
              <p><strong>Départ :</strong> <%= booking.end_date %></p>
              <p><strong>Total :</strong> <%= booking.total_price %>€</p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
