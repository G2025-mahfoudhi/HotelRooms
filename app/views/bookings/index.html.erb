<%# <h1>Bookings#index</h1> %>
<%# <p>Find me in app/views/bookings/index.html.erb</p> %>
<div class="container mt-5">
  <h1 class="mb-4">Mes réservations</h1>

  <% if @bookings.empty? %>
    <div class="empty-state text-center py-5">
      <i class="bi bi-calendar-x empty-icon"></i>
      <h4 class="mt-3">Aucune réservation pour le moment</h4>
      <p class="text-muted">Explorez nos hôtels et réservez votre séjour !</p>
      <%= link_to "Voir les hôtels", root_path, class: "btn btn-primary mt-2" %>
    </div>
  <% else %>
    <div class="row">
      <% @bookings.each do |booking| %>
        <div class="col-md-6 mb-4">
          <div class="booking-card">
            <% if booking.room.photo.attached? %>
              <%= image_tag booking.room.photo, class: "booking-img" %>
            <% else %>
              <img src="<%= booking.room.hotel.photo_url %>" class="booking-img" alt="<%= booking.room.hotel.name %>">
            <% end %>
            <div class="booking-body">
              <h5><%= booking.room.hotel.name %></h5>
              <p><i class="bi bi-door-open me-2"></i><%= booking.room.room_type %></p>
              <p><i class="bi bi-calendar-check me-2"></i>Arrivée : <%= booking.start_date.strftime("%d/%m/%Y") %></p>
              <p><i class="bi bi-calendar-x me-2"></i>Départ : <%= booking.end_date.strftime("%d/%m/%Y") %></p>
              <p><i class="bi bi-moon me-2"></i><%= (booking.end_date - booking.start_date).to_i %> nuit(s)</p>
            </div>
            <div class="booking-footer">
              <span>Total</span>
              <span class="booking-price"><%= booking.total_price %>€</span>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
