<% if resource.errors.any? %>
  <div class="alert alert-danger">
    <h6 class="fw-bold">
      <%= I18n.t("errors.messages.not_saved", count: resource.errors.count) %>
    </h6>
    <ul class="mb-0">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
