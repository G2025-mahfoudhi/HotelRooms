<!DOCTYPE html>
<html>
  <head>
    <title>HotelRooms</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top" style="background-color: #1a1a2e;">
      <div class="container">
        <%= link_to root_path, class: "navbar-brand d-flex align-items-center gap-2" do %>
          <i class="bi bi-building" style="font-size: 1.5rem; color: #f0a500;"></i>
          HotelRooms
        <% end %>
        <div class="d-flex gap-2">
          <% if user_signed_in? %>
            <%= link_to "Admin", admin_hotels_path, class: "btn btn-outline-warning btn-sm" %>
            <%= link_to "Mes réservations", bookings_path, class: "btn btn-outline-light btn-sm" %>
            <%= link_to "Déconnexion", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-outline-light btn-sm" %>
          <% else %>
            <%= link_to "Connexion", new_user_session_path, class: "btn btn-outline-light btn-sm" %>
            <%= link_to "Inscription", new_user_registration_path, class: "btn btn-warning btn-sm" %>
          <% end %>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="alert alert-success alert-dismissible m-3"><%= notice %></div>
    <% end %>
    <% if alert %>
      <div class="alert alert-danger alert-dismissible m-3"><%= alert %></div>
    <% end %>

    <%= yield %>

    <footer class="mt-5 py-4 text-center">
      <p class="mb-0">© 2026 HotelRooms — Tous droits réservés</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
